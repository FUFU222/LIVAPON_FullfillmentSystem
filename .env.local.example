# ===========================================================
# .env.local テンプレート
# このファイルを .env.local にコピーして値を埋めてください。
# .env.local は git にコミットされません。
# ===========================================================

# ----------- アプリ側(Next.js)の Supabase 接続 ------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ----------- サーバー/seed スクリプト用(service role) --------
# Supabase ダッシュボード → Project Settings → API → service_role key
# 注: 絶対にクライアント側に露出させないこと
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ----------- 納品書 PDF の発行者情報(任意・未設定なら CHAIRMAN) -----
# PACKING_SLIP_ISSUER_NAME=株式会社CHAIRMAN (LIVAPON)
# PACKING_SLIP_ISSUER_POSTAL=107-0062
# PACKING_SLIP_ISSUER_ADDRESS=東京都港区南青山2-2-15
# PACKING_SLIP_ISSUER_EMAIL=information@chairman.jp

# ----------- E2E (Playwright) テスト用(必要時のみ) ----------
# .env.e2e.example を参照
